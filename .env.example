# Copy to .env  (cp .env.example .env)  and fill in real values.
# .env is gitignored — secrets NEVER get committed.

APP_ENV=development
LOG_LEVEL=INFO

DATABASE_URL=postgresql+asyncpg://eka:eka@localhost:5432/eka
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001

LLM_PROVIDER=gemini
GEMINI_API_KEY=paste-your-AIza-key-here
